# exports.zsh — copy this file to exports.zsh and fill in your values.
# exports.zsh is gitignored; exports.zsh.example is committed as a template.
#
# Usage: cp zsh/exports.zsh.example zsh/exports.zsh  (done automatically by link.sh)

# ── Editor ────────────────────────────────────────────────────────────────────
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat"

# ── Language / locale ─────────────────────────────────────────────────────────
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# ── XDG base dirs ─────────────────────────────────────────────────────────────
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# ── Azure ─────────────────────────────────────────────────────────────────────
export AZURE_SUBSCRIPTION_ID="your-subscription-id"
export AZURE_TENANT_ID="your-tenant-id"
export AZURE_CLIENT_ID=""                   # Service principal (optional)
export AZURE_CLIENT_SECRET=""               # Service principal (optional)
export ARM_SUBSCRIPTION_ID="$AZURE_SUBSCRIPTION_ID"
export ARM_TENANT_ID="$AZURE_TENANT_ID"
# export ARM_CLIENT_ID="$AZURE_CLIENT_ID"
# export ARM_CLIENT_SECRET="$AZURE_CLIENT_SECRET"

# ── Databricks ────────────────────────────────────────────────────────────────
export DATABRICKS_HOST="https://adb-XXXXX.azuredatabricks.net"
export DATABRICKS_TOKEN=""                  # Personal access token
# export DATABRICKS_CLUSTER_ID=""

# ── Terraform ─────────────────────────────────────────────────────────────────
export TF_LOG=""                            # DEBUG | INFO | WARN | ERROR
export TF_LOG_PATH="$HOME/.terraform.log"
# export TF_VAR_environment="dev"

# ── Python / uv ───────────────────────────────────────────────────────────────
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUNBUFFERED=1
export UV_PYTHON="3.12"
export PYENV_ROOT="$HOME/.pyenv"

# ── Docker ────────────────────────────────────────────────────────────────────
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# ── Kubernetes ────────────────────────────────────────────────────────────────
# export KUBECONFIG="$HOME/.kube/config:$HOME/.kube/config-dev"
export KUBE_EDITOR="nvim"

# ── GitHub / GitLab ───────────────────────────────────────────────────────────
export GITHUB_TOKEN=""
export GITLAB_TOKEN=""
export GIT_AUTHOR_NAME="Your Name"
export GIT_AUTHOR_EMAIL="your@email.com"

# ── DigitalOcean ──────────────────────────────────────────────────────────────
export DIGITALOCEAN_TOKEN=""
export DIGITALOCEAN_SPACES_KEY=""
export DIGITALOCEAN_SPACES_SECRET=""

# ── SSH ───────────────────────────────────────────────────────────────────────
export SSH_KEY_PATH="$HOME/.ssh/id_ed25519"

# ── GPG ───────────────────────────────────────────────────────────────────────
export GPG_TTY="$(tty)"

# ── Misc API keys (examples) ─────────────────────────────────────────────────
# export OPENAI_API_KEY=""
# export ANTHROPIC_API_KEY=""
# export DATADOG_API_KEY=""

# ── Airflow ───────────────────────────────────────────────────────────────────
# export AIRFLOW_HOME="$HOME/airflow"
# export AIRFLOW__CORE__EXECUTOR="LocalExecutor"

# ── Machine-specific overrides ────────────────────────────────────────────────
# Anything that differs between machines goes in ~/.zshrc.local (not committed)
