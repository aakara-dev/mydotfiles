zsh/exports.zsh
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.pfx

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editors
.idea/
*.swp
*.swo
*~
.vscode/settings.json

# Python
__pycache__/
*.pyc
.venv/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
